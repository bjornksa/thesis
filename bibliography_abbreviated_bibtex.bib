  urldate = {2024-10-31},
  abstract = {We re-examine the time-dependent harmonic oscillator \${\textbackslash}ddot q=-{\textbackslash}omega{\textasciicircum}2 q\$ under various regularity assumptions. Where \${\textbackslash}omega(t)\$ is continuously differentiable we reduce its integration to that of a single first order equation, i.e. the Hamilton equation for the angle variable \${\textbackslash}psi\$ alone (the action variable \$\{{\textbackslash}cal I\}\$ does not appear). Reformulating the generic Cauchy problem for \${\textbackslash}psi(t)\$ as a Volterra-type integral equation and applying the fixed point theorem we obtain a sequence \${\textbackslash}\{{\textbackslash}psi{\textasciicircum}\{(h)\}{\textbackslash}\}\_\{h{\textbackslash}in{\textbackslash}mathbb\{N\}\_0\}\$ converging uniformly to \${\textbackslash}psi\$ in every compact time interval; if \${\textbackslash}omega\$ varies slowly or little, already \${\textbackslash}psi{\textasciicircum}\{(0)\}\$ approximates \${\textbackslash}psi\$ well for rather long time lapses. The discontinuities of \${\textbackslash}omega\$, if any, determine those of \${\textbackslash}psi,\{{\textbackslash}cal I\}\$. The zeroes of \$q,{\textbackslash}dot q\$ are investigated with the help of two Riccati equations. As a demo of the potential of our approach, we briefly argue that it yields good approximations of the solutions (as well as exact bounds on them) and thereby may simplify the study of: the stability of the trivial one; the occurrence of parametric resonance when \${\textbackslash}omega(t)\$ is periodic; the adiabatic invariance of \$\{{\textbackslash}cal I\}\$; the asymptotic expansions in a slow time parameter \${\textbackslash}varepsilon\$; etc.},
  archiveprefix = {arXiv},
  keywords = {Mathematical Physics,Mathematics - Mathematical Physics},
  file = {/Users/madserlendlyso/Zotero/storage/52LLJRCC/Fiore_2022_The time-dependent harmonic oscillator revisited.pdf;/Users/madserlendlyso/Zotero/storage/B8XQ4NWA/2205.html}
}

