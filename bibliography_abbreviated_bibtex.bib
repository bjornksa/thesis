@article{nirmalPhaseShiftControl2021,
  title = {Phase Shift Control and Controller Area Network Assisted Proportional Resonant Control for Grid Integration of Single Phase Voltage Source Inverters},
  author = {Nirmal, S. and Sivarajan, K. N. and Jasmin, E. A.},
  year = 2021,
