@article{zhaoOrbitalStabilityAnalysis2020,
  title = {Orbital {{Stability Analysis}} for {{Perturbed Nonlinear Systems}} and {{Natural Entrainment}} via {{Adaptive Andronov}}--{{Hopf Oscillator}}},
