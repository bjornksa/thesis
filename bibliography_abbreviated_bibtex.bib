@article{zhaoMulticontactBipedalRobotic2017,
  title = {Multi-Contact Bipedal Robotic Locomotion},
  author = {Zhao, Huihua and Hereid, Ayonga and Ma, Wen-loong and Ames, Aaron D.},
  year = 2017,
  month = may,
  journal = {Robotica},
