  booktitle = {Proc. {{IEEE}} 4th {{Conf}}. {{Energy Internet}} and {{Energy Sys}}. {{Integr}}.},
  author = {Abdelbaky, Mohamed Abdelkarim and Emara, Hassan Mohammed and {El-Hawwary}, Mohamed I. and Bahgat, Ahmed and Liu, Xiangjie},
  year = 2020,
