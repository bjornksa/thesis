  author = {Lys{\o}, Mads Erlend B{\o}e and Panteley, Elena and Orucevic, Amer and Pettersen, Kristin Y and Gravdahl, Jan Tommy},
  year = 2025,
  month = aug,
  journal = {IEEE TAC, Submitted},
  abstract = {We address the problems of generating and stabilizing locomotion gait patterns in rigid multibody systems such as floating-base robots, via an approach that recasts the pattern stabilization problem into one of dynamic synchronization of a network of oscillators, each representing a joint of the system. Thus, we avoid the common separation into pattern generation and trajectory tracking, which may result in undesired transient behavior. Our framework is fairly general: The generated patterns cover families of sinusoidal oscillations typically encountered in approaches relying on the separation of gait generation and tracking control, as well as those produced by central pattern generators. In particular, gait patterns of arbitrary amplitudes and phase-shifts, as well as arbitrary time-varying frequency and offset are generated and stabilized. Furthermore, for the first time in the literature, we provide formal proof of almost global uniform-in-time asymptotic stability for the closed-loop system. In addition, the practical interest of our rigorous method is demonstrated in simulation studies of an underwater snake robot, using a high-fidelity computational fluid dynamics simulator.},
  langid = {english},
  file = {/Users/madserlendlyso/Zotero/storage/5VCKQXWC/Lysø et al. - A Dynamic Consensus Approach to Locomotion Control.pdf}
}

