  shorttitle = {Two-{{Stage Optimized Trajectory Planning}} for {{ASVs Under Polygonal Obstacle Constraints}}},
  author = {Bitar, Glenn and Martinsen, Andreas B. and Lekkas, Anastasios M. and Breivik, Morten},
  year = {2020},
  journal = {IEEE Access},
  volume = {8},
