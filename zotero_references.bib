@article{Lauer2011aco,
  title = {A Continuous Optimization Framework for Hybrid System Identification},
  author = {Lauer, Fabien and Bloch, G{\'e}rard and Vidal, Ren{\'e}},
  year = {2011},
  journal = {Automatica},
  volume = {47},
  number = {3},
  pages = {608--613},
  issn = {0005-1098},
  doi = {10.1016/j.automatica.2011.01.020},
  url = {http://www.sciencedirect.com/science/article/pii/S0005109811000355},
  abstract = {We propose a new framework for hybrid system identification, which relies on continuous optimization. This framework is based on the minimization of a cost function that can be chosen as either the minimum or the product of loss functions. The former is inspired by traditional estimation methods, while the latter is inspired by recent algebraic and support vector regression approaches to hybrid system identification. In both cases, the identification problem is recast as a continuous optimization program involving only the real parameters of the model as variables, thus avoiding the use of discrete optimization. This program can be solved efficiently by using standard optimization methods even for very large data sets. In addition, the proposed framework easily incorporates robustness to different kinds of outliers through the choice of the loss function.},
  keywords = {Hybrid system,Identification,Large data set,Robustness to outliers}
