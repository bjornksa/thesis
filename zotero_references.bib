@article{Krahenbuhl2016ddi,
  title = {Data-Dependent {{Initializations}} of {{Convolutional Neural Networks}}},
  author = {Kr{\"a}henb{\"u}hl, Philipp and Doersch, Carl and Donahue, Jeff and Darrell, Trevor},
  year = {2016},
