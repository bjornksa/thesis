@article{Heiberg2022rbi,
  title = {Risk-Based Implementation of {{COLREGs}} for Autonomous Surface Vehicles Using Deep Reinforcement Learning},
  author = {Heiberg, Amalie and Larsen, Thomas Nakken and Meyer, Eivind and Rasheed, Adil and San, Omer and Varagnolo, Damiano},
  year = {2022},
  month = aug,
  journal = {Neural Networks},
