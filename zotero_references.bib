@article{Fiorentini2017hmp,
  title = {Hybrid Model Predictive Control of a Residential {{HVAC}} System with On-Site Thermal Energy Generation and Storage},
  author = {Fiorentini, M. and Wall, J. and Ma, Z. and Braslavsky, J.H. and Cooper, P.},
