GS
[0.48 0 0 0.48008 0 482.48322] CT
[1 0 0 1 0 0] CT
N
0 -1005 M
2500 -1005 L
2500 928 L
0 928 L
0 -1005 L
cp
clip
GS
0 0 translate
1200 928 scale
%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 928
  /ImageMatrix [1200 0 0 928 0 0]
  /Width 1200
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
