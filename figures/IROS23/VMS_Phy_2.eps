{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 350
  /ImageMatrix [350 0 0 350 0 0]
  /Width 350
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
